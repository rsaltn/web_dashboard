# Server Configuration
PORT=3000

# Google Gemini API (required for AI features)
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot Configuration (required for teacher notifications)
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Director's Telegram Chat ID (optional, for receiving teacher messages)
# Get your chat ID by messaging the bot and using /chatid command
DIRECTOR_CHAT_ID=your_director_chat_id_here

# Teachers Group Chat ID (optional, for group notifications)
TEACHERS_GROUP_CHAT_ID=your_group_chat_id_here
